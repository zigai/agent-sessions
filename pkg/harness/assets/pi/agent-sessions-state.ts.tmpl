"{{MANAGED_MARKER}}";
"AGENT_SESSIONS_INTEGRATION_ID={{INTEGRATION_ID}}";
"AGENT_SESSIONS_INTEGRATION_VERSION={{INTEGRATION_VERSION}}";
"agent_sessions_integration_version={{INTEGRATION_VERSION}}";

import { spawn } from "node:child_process";

const agentSessionsBin = {{BINARY}};
const currentSessionSource = {{SOURCE}};

let currentSessionId: string | undefined;
let currentSessionPath: string | undefined;
let currentCwd: string | undefined;

function updateSessionRef(ctx: any): void {
  try {
    const file = ctx?.sessionManager?.getSessionFile?.();
    currentSessionPath = typeof file === "string" && file.length > 0 ? file : undefined;
  } catch {
    currentSessionPath = undefined;
  }

  try {
    const id = ctx?.sessionManager?.getSessionId?.();
    currentSessionId = typeof id === "string" && id.length > 0 ? id : undefined;
  } catch {
    currentSessionId = undefined;
  }

  currentCwd = typeof ctx?.cwd === "string" && ctx.cwd.length > 0 ? ctx.cwd : undefined;
}

function addAttribute(args: string[], key: string, value: unknown): void {
  if (typeof value === "string" && value.length > 0) {
    args.push("--attribute", `${key}=${value}`);
  }
}

function addEvent(args: string[], value: unknown): void {
  if (typeof value === "string" && value.length > 0) {
    args.push("--event", value);
  }
}

function report(transition: string, ctx?: any, event?: any): void {
  const observedAt = new Date().toISOString();
  if (ctx) {
    updateSessionRef(ctx);
  }

  const args = ["report", "pi", "--observed-at", observedAt, "--queue", "--quiet"];
  args.push(transition === "gone" ? "--presence" : "--activity", transition);
  args.push("--attribute", `agent_sessions_integration_version={{INTEGRATION_VERSION}}`);
  args.push("--attribute", `agent_sessions_integration=${currentSessionSource}`);
  if (currentSessionPath) {
    args.push("--session-path", currentSessionPath);
  } else if (currentSessionId) {
    args.push("--session-id", currentSessionId);
  }
  if (currentCwd) {
    args.push("--cwd", currentCwd);
  }
  addAttribute(args, "pi_event", event?.type);
  addAttribute(args, "pi_reason", event?.reason);

  try {
    const child = spawn(agentSessionsBin, args, {
      detached: true,
      stdio: "ignore",
    });
    child.on("error", () => {});
    child.unref();
  } catch {
    // Session reporting must never break Pi startup or turns.
  }
}
export default function (pi: any) {
  pi.on("session_start", (event: any, ctx: any) => {
    report("idle", ctx, event);
  });

  pi.on("before_agent_start", (event: any, ctx: any) => {
    report("running", ctx, event);
  });

  pi.on("agent_start", (event: any, ctx: any) => {
    report("running", ctx, event);
  });

  pi.on("agent_settled", (event: any, ctx: any) => {
    report("idle", ctx, event);
  });

  pi.on("session_shutdown", (event: any, ctx: any) => {
    report("gone", ctx, event);
  });
}
