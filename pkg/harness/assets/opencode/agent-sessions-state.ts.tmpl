"{{MANAGED_MARKER}}";
"AGENT_SESSIONS_INTEGRATION_ID={{INTEGRATION_ID}}";
"AGENT_SESSIONS_INTEGRATION_VERSION={{INTEGRATION_VERSION}}";
"agent_sessions_integration_version={{INTEGRATION_VERSION}}";

import { spawn } from "node:child_process";

const agentSessionsBin = {{BINARY}};
const source = {{SOURCE}};


function firstString(...values: unknown[]): string | undefined {
  for (const value of values) {
    if (typeof value === "string" && value.length > 0) {
      return value;
    }
  }
  return undefined;
}

function valueAt(value: any, path: string[]): unknown {
  let current = value;
  for (const part of path) {
    if (current === undefined || current === null || typeof current !== "object") {
      return undefined;
    }
    current = current[part];
  }
  return current;
}

function firstPathString(value: any, paths: string[][]): string | undefined {
  return firstString(...paths.map((path) => valueAt(value, path)));
}

function normalizeStatus(value: unknown): string | undefined {
  if (value !== null && typeof value === "object") {
    value = (value as { type?: unknown }).type;
  }
  if (typeof value !== "string") {
    return undefined;
  }
  const status = value.toLowerCase();
  if (["running", "busy", "retry"].includes(status)) {
    return "running";
  }
  if (status === "idle" || status === "offline") {
    return "idle";
  }
  return undefined;
}

function stateForEvent(event: any): string | undefined {
  switch (event?.type) {
    case "session.created":
      return "idle";
    case "session.idle":
      return "idle";
    case "permission.asked":
      return "waiting";
    case "permission.replied":
      return "running";
    case "session.status":
      return normalizeStatus(firstPathString(event, [
        ["status", "type"],
        ["properties", "status", "type"],
        ["session", "status", "type"],
        ["status"],
        ["properties", "status"],
        ["session", "status"],
      ]));
    default:
      return undefined;
  }
}

async function AgentSessionsPlugin(ctx: any): Promise<any> {
  let currentSessionId: string | undefined;
  let currentSessionPath: string | undefined;
  let currentCwd: string | undefined;
  let currentProjectRoot: string | undefined;

  function refreshSessionRef(event: any): void {
    currentSessionId = firstPathString(event, [
      ["sessionID"],
      ["sessionId"],
      ["session_id"],
      ["properties", "sessionID"],
      ["properties", "sessionId"],
      ["properties", "session_id"],
      ["properties", "info", "id"],
      ["properties", "info", "sessionID"],
      ["session", "id"],
      ["session", "sessionID"],
      ["session", "sessionId"],
    ]) ?? currentSessionId;

    currentSessionPath = firstPathString(event, [
      ["sessionPath"],
      ["session_path"],
      ["path"],
      ["properties", "info", "path"],
      ["properties", "info", "file"],
      ["session", "path"],
      ["session", "file"],
    ]) ?? currentSessionPath;

    currentCwd = firstString(
      ctx?.directory,
      ctx?.worktree,
      event?.cwd,
      event?.session?.cwd,
      event?.properties?.cwd,
      event?.properties?.info?.directory,
    ) ?? currentCwd;

    currentProjectRoot = firstString(
      ctx?.worktree,
      ctx?.project?.path,
      ctx?.project?.root,
      event?.properties?.info?.directory,
    ) ?? currentProjectRoot;
  }

function addAttribute(args: string[], key: string, value: unknown): void {
  if (typeof value === "string" && value.length > 0) {
    args.push("--attribute", `${key}=${value}`);
  }
}

function addEvent(args: string[], value: unknown): void {
  if (typeof value === "string" && value.length > 0) {
    args.push("--event", value);
  }
}

  function report(state: string, event: any): void {
    const observedAt = new Date().toISOString();
    refreshSessionRef(event);

    const args = ["report", "opencode", "--activity", state, "--observed-at", observedAt, "--queue", "--quiet"];
    addEvent(args, event?.type);
    args.push("--attribute", `agent_sessions_integration_version={{INTEGRATION_VERSION}}`);
    if (currentSessionId) {
      args.push("--session-id", currentSessionId);
    }
    if (currentSessionPath) {
      args.push("--session-path", currentSessionPath);
    }
    if (currentCwd) {
      args.push("--cwd", currentCwd);
    }
    if (currentProjectRoot) {
      args.push("--project-root", currentProjectRoot);
    }

    addAttribute(args, "opencode_status", firstPathString(event, [
      ["status", "type"],
      ["properties", "status", "type"],
      ["session", "status", "type"],
      ["status"],
      ["properties", "status"],
      ["session", "status"],
    ]));
    addAttribute(args, "agent_sessions_integration", source);

    try {
      const child = spawn(agentSessionsBin, args, {
        detached: true,
        stdio: "ignore",
      });
      child.on("error", () => {});
      child.unref();
    } catch {
      // Session reporting must never break OpenCode startup or turns.
    }
  }

  return {
    event: async ({ event }: any) => {
      const state = stateForEvent(event);
      if (state === undefined) {
        return;
      }

      report(state, event);
    },
  };
}

export default { id: "agent-sessions-state", server: AgentSessionsPlugin };
